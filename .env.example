# Server
PORT=8000
CLIENT_URL=http://localhost:5173
ADMIN_PASSWORD=change-me

# Database path is auto-resolved to server/data/queries.db
# No DATABASE_URL needed — SQLite is file-based

# Email notifications (leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=admin@yourdomain.com

# Telegram notifications (leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
